{
  "name": "kumiko-framework",
  "version": "0.0.0",
  "description": "Config-driven, command-based, realtime multi-tenant app framework.",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "license": "BUSL-1.1",
  "author": "Marc Frost <marc@cosmicdriftgamestudio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmicdriftgamestudio/kumiko-framework.git"
  },
  "bugs": {
    "url": "https://github.com/cosmicdriftgamestudio/kumiko-framework/issues"
  },
  "homepage": "https://kumiko.so",
  "keywords": [
    "framework",
    "multi-tenant",
    "realtime",
    "command-based",
    "config-driven",
    "typescript",
    "bun",
    "hono",
    "drizzle",
    "postgres"
  ],
  "workspaces": [
    "packages/framework",
    "packages/bundled-features",
    "packages/dev-server",
    "packages/headless",
    "packages/dispatcher-live",
    "packages/renderer",
    "packages/renderer-web",
    "samples/recipes/*",
    "samples/apps/*"
  ],
  "scripts": {
    "kumiko": "NODE_OPTIONS=--no-deprecation bun run bin/kumiko.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "vitest --config vitest.all.config.ts",
    "typecheck": "tsc --build",
    "build:apps": "bun run scripts/build-apps.ts",
    "build": "echo 'kumiko-framework: TypeScript source is published as-is (Bun resolver), no transpile step.'",
    "postinstall": "bun run scripts/codegen-samples.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.31.0",
    "@cosmicdriftgamestudio/kumiko-guards": "^0.1.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "bun-types": "^1.3.12",
    "husky": "^9.1.7",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4",
    "yaml": "^2.8.4"
  },
  "resolutions": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
