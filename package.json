{
  "name": "kumiko-framework",
  "version": "0.0.0",
  "description": "Config-driven, command-based, realtime multi-tenant app framework.",
  "private": true,
  "license": "BUSL-1.1",
  "author": "Marc Frost <marc@cosmicdriftgamestudio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmicDriftGameStudio/kumiko-framework.git"
  },
  "bugs": {
    "url": "https://github.com/CosmicDriftGameStudio/kumiko-framework/issues"
  },
  "homepage": "https://kumiko.rocks",
  "keywords": [
    "framework",
    "multi-tenant",
    "realtime",
    "command-based",
    "config-driven",
    "typescript",
    "bun",
    "hono",
    "drizzle",
    "postgres"
  ],
  "workspaces": [
    "packages/framework",
    "packages/bundled-features",
    "packages/cli",
    "packages/create-kumiko-app",
    "packages/dev-server",
    "packages/headless",
    "packages/dispatcher-live",
    "packages/renderer",
    "packages/renderer-web",
    "samples/recipes/*",
    "samples/apps/*"
  ],
  "trustedDependencies": [
    "@parcel/watcher",
    "msgpackr-extract"
  ],
  "bin": {
    "kumiko": "./bin/kumiko.ts"
  },
  "scripts": {
    "kumiko": "bun run bin/kumiko.ts",
    "test": "bun test --dots",
    "test:dom-isolated": "bun test --config=bunfig.ci-dom.toml ./packages/bundled-features/src/user-data-rights/web/__tests__/deletion-screens.test.tsx && bun test --config=bunfig.ci-dom.toml ./packages/bundled-features/src/user-data-rights/web/__tests__/privacy-center-screen.test.tsx",
    "test:run": "bun test --dots",
    "test:verbose": "bun test",
    "test:integration": "bun scripts/run-integration-tests.ts",
    "test:integration:perf:flaky": "KUMIKO_PERF_GATE=1 bun test --dots --config=bunfig.integration.toml packages/framework/src/pipeline/__tests__/perf-rebuild.integration.test.ts",
    "test:integration:perf:strict": "KUMIKO_PERF_GATE=1 bun test --dots --config=bunfig.integration.toml packages/framework/src/event-store/__tests__/perf.integration.test.ts packages/framework/src/event-store/__tests__/get-stream-version-perf.integration.test.ts packages/framework/src/engine/__tests__/pipeline-performance.integration.test.ts",
    "test:integration:perf": "KUMIKO_PERF_GATE=1 bun scripts/run-integration-tests.ts --perf",
    "typecheck": "tsc --build",
    "build:apps": "bun run scripts/build-apps.ts",
    "build": "echo 'kumiko-framework: TypeScript source is published as-is (Bun resolver), no transpile step.'",
    "gen:sample-index": "bun run samples/apps/use-all-bundled/scripts/gen-sample-index.ts",
    "gen:feature-screenshots": "bun run samples/scripts/gen-feature-screenshots.ts",
    "postinstall": "bun run scripts/codegen-samples.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@cosmicdriftgamestudio/kumiko-guards": "^0.13.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "bun-types": "^1.3.13",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "resolutions": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "dependencies": {
    "ink": "^7.0.3",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0"
  }
}

