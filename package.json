{
  "name": "kumiko",
  "description": "Config-driven, command-based, realtime multi-tenant app framework.",
  "private": true,
  "license": "BUSL-1.1",
  "author": "Marc Frost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bender0oo0/kumiko.git"
  },
  "bugs": {
    "url": "https://github.com/bender0oo0/kumiko/issues"
  },
  "homepage": "https://github.com/bender0oo0/kumiko#readme",
  "keywords": [
    "framework",
    "multi-tenant",
    "realtime",
    "command-based",
    "config-driven",
    "typescript",
    "bun",
    "hono",
    "drizzle",
    "postgres"
  ],
  "workspaces": [
    "packages/framework",
    "packages/bundled-features",
    "packages/headless",
    "packages/dispatcher-live",
    "packages/renderer",
    "packages/renderer-web",
    "samples/recipes/*",
    "samples/apps/*",
    "samples/showcases/*",
    "app"
  ],
  "scripts": {
    "kumiko": "NODE_OPTIONS=--no-deprecation bun run bin/kumiko.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "vitest --config vitest.all.config.ts",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.4",
    "bun-types": "^1.3.12",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
