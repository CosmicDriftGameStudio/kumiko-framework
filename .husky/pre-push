#!/usr/bin/env sh
# Pre-push hook — runs scoped `yarn check` before allowing push.
#
# Logic:
#   1. If running inside the cosmicdriftgamestudio Parent-Workspace,
#      delegate to its `yarn check` with KUMIKO_CLI_SCOPE set to THIS
#      sub-repo only — so a push from kumiko-framework doesn't run
#      Biome/TS/Tests for kumiko-studio/-enterprise/-platform/
#      publicstatus as well.
#
#      NB: cross-repo Guards (infra/guards) keep their full scan, so
#      Drift introduced in another repo still surfaces here. Use
#      `KUMIKO_GUARD_ROOTS` to scope guard scan explicitly when you
#      know what you're doing.
#   2. Else (standalone clone outside the parent workspace): run the
#      sub-repo's own `yarn test:run`.
#
# Override: set PRE_PUSH_SKIP=1 to bypass (use sparingly).

if [ "${PRE_PUSH_SKIP:-0}" = "1" ]; then
  echo "[pre-push] PRE_PUSH_SKIP=1 — Hook übersprungen"
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
REPO_NAME="$(basename "$REPO_ROOT")"
PARENT_DIR="$(cd "$REPO_ROOT/.." && pwd)"

if [ -f "$PARENT_DIR/package.json" ] \
   && grep -q '"name": *"cosmicdriftgamestudio"' "$PARENT_DIR/package.json" 2>/dev/null; then
  echo "[pre-push] yarn check (scoped: $REPO_NAME)…"
  cd "$PARENT_DIR" && KUMIKO_CLI_SCOPE="$REPO_NAME" yarn check
else
  echo "[pre-push] yarn test:run (standalone)…"
  cd "$REPO_ROOT" && yarn test:run
fi
