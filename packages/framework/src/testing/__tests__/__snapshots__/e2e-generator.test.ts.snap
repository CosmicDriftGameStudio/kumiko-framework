// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderPlaywrightSpec > produces stable output (snapshot) 1`] = `
"// Auto-generated by @kumiko/framework/testing — do not edit by hand.
// Regenerate via the CLI once the screens change.
import { test, expect } from "@playwright/test";

async function postWrite(request: import("@playwright/test").APIRequestContext, handler: string, data: unknown) {
  const res = await request.post("/api/write", { data: { handler, data } });
  expect(res.ok(), await res.text()).toBe(true);
  return res.json();
}

test("tasks/task-list — list renders", async ({ page }) => {
  await page.goto("/t/{tenant}/tasks/task-list");
  await expect(page.getByRole("table")).toBeVisible();
});

test("tasks/task-list — list shows seeded row", async ({ page, request }) => {
  await postWrite(request, "tasks:write:task:create", {"title":"e2e title","done":true,"status":"todo"});
  await page.goto("/t/{tenant}/tasks/task-list");
  await expect(page.getByText("e2e title")).toBeVisible();
});

test("tasks/task-edit — edit validates required (title)", async ({ page }) => {
  await page.goto("/t/{tenant}/tasks/task-edit");
  await page.getByRole("button", { name: /save|speichern/i }).click();
  for (const field of ["title"]) {
    await expect(page.getByTestId(\`field-error-\${field}\`)).toBeVisible();
  }
});

test("tasks/task-edit — edit saves and persists", async ({ page }) => {
  await page.goto("/t/{tenant}/tasks/task-edit");
  await page.getByTestId("field-title").fill("e2e title");
  await page.getByTestId("field-status").selectOption("todo");
  await page.getByTestId("field-done").setChecked(true);
  await page.getByRole("button", { name: /save|speichern/i }).click();
  await page.goto("/t/{tenant}/tasks/task-list");
  await expect(page.getByText("e2e title")).toBeVisible();
});
"
`;
