{
  "name": "@cosmicdrift/kumiko-headless",
  "version": "0.107.0",
  "description": "Headless UI logic for Kumiko — Dispatcher contract, Form-Controller, View-Model, Nav-Resolver. Plattform- und React-frei; jeder Renderer (renderer, renderer-web, renderer-native, …) komponiert darauf.",
  "license": "BUSL-1.1",
  "author": "Marc Frost <marc@cosmicdriftgamestudio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmicDriftGameStudio/kumiko-framework.git",
    "directory": "packages/headless"
  },
  "bugs": {
    "url": "https://github.com/CosmicDriftGameStudio/kumiko-framework/issues"
  },
  "homepage": "https://kumiko.rocks",
  "type": "module",
  "kumiko": {
    "runtime": "client"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./dispatcher": {
      "types": "./src/dispatcher/index.ts",
      "default": "./src/dispatcher/index.ts"
    },
    "./apex": {
      "types": "./src/apex/index.ts",
      "default": "./src/apex/index.ts"
    }
  },
  "dependencies": {
    "@cosmicdrift/kumiko-framework": "workspace:*",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
