{
  "name": "@cosmicdrift/kumiko-dev-server",
  "version": "0.159.1",
  "description": "Dev-tooling for Kumiko apps: local dev-server bootstrap (runDevApp), scaffolding, codegen. Not shipped into production node_modules — see @cosmicdrift/kumiko-server-runtime for the prod boot path.",
  "license": "BUSL-1.1",
  "author": "Marc Frost <marc@cosmicdriftgamestudio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmicDriftGameStudio/kumiko-framework.git",
    "directory": "packages/dev-server"
  },
  "bugs": {
    "url": "https://github.com/CosmicDriftGameStudio/kumiko-framework/issues"
  },
  "homepage": "https://kumiko.rocks",
  "type": "module",
  "kumiko": {
    "runtime": "dev"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./build": {
      "types": "./src/build.ts",
      "default": "./src/build.ts"
    },
    "./compose-stacks": {
      "types": "./src/compose-stacks.ts",
      "default": "./src/compose-stacks.ts"
    },
    "./setup-test-stack-from-features": {
      "types": "./src/setup-test-stack-from-features.ts",
      "default": "./src/setup-test-stack-from-features.ts"
    },
    "./schema-apply": {
      "types": "./src/schema-apply.ts",
      "default": "./src/schema-apply.ts"
    },
    "./schema-tables-auth-mode": {
      "types": "./src/schema-tables-auth-mode.ts",
      "default": "./src/schema-tables-auth-mode.ts"
    },
    "./schema-tables-minimal": {
      "types": "./src/schema-tables-minimal.ts",
      "default": "./src/schema-tables-minimal.ts"
    }
  },
  "bin": {
    "kumiko-build": "./bin/kumiko-build.ts",
    "kumiko-dev": "./bin/kumiko-dev.ts",
    "kumiko-schema": "./bin/kumiko-schema.ts",
    "kumiko-schema-check": "./bin/kumiko-schema-check.ts"
  },
  "dependencies": {
    "@cosmicdrift/kumiko-bundled-features": "workspace:*",
    "@cosmicdrift/kumiko-framework": "workspace:*",
    "@cosmicdrift/kumiko-server-runtime": "workspace:*",
    "ts-morph": "^28.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ]
}
