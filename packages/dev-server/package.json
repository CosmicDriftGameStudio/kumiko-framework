{
  "name": "@cosmicdrift/kumiko-dev-server",
  "version": "0.12.2",
  "description": "Development server bootstrap for Kumiko apps. Bundles the client, mints dev-JWTs, injects the resolved AppSchema, and seeds an admin. Not for production.",
  "license": "BUSL-1.1",
  "author": "Marc Frost <marc@cosmicdriftgamestudio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmicDriftGameStudio/kumiko-framework.git",
    "directory": "packages/dev-server"
  },
  "bugs": {
    "url": "https://github.com/CosmicDriftGameStudio/kumiko-framework/issues"
  },
  "homepage": "https://kumiko.so",
  "type": "module",
  "kumiko": {
    "runtime": "dev"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./build": {
      "types": "./src/build.ts",
      "default": "./src/build.ts"
    },
    "./compose-features": {
      "types": "./src/compose-features.ts",
      "default": "./src/compose-features.ts"
    },
    "./drizzle-config": {
      "types": "./src/drizzle-config.ts",
      "default": "./src/drizzle-config.ts"
    },
    "./drizzle-tables-auth-mode": {
      "types": "./src/drizzle-tables-auth-mode.ts",
      "default": "./src/drizzle-tables-auth-mode.ts"
    },
    "./drizzle-tables-minimal": {
      "types": "./src/drizzle-tables-minimal.ts",
      "default": "./src/drizzle-tables-minimal.ts"
    }
  },
  "bin": {
    "kumiko-build": "./bin/kumiko-build.ts",
    "kumiko-dev": "./bin/kumiko-dev.ts",
    "kumiko-schema-check": "./bin/kumiko-schema-check.ts"
  },
  "dependencies": {
    "@cosmicdrift/kumiko-bundled-features": "workspace:*",
    "@cosmicdrift/kumiko-framework": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ]
}
