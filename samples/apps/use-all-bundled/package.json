{
  "name": "@cosmicdrift/kumiko-sample-use-all-bundled",
  "description": "Canonical smoke-sample — mounts every bundled-feature so framework-CI catches feature-coverage gaps that real apps (which mount only what they use) miss.",
  "private": true,
  "type": "module",
  "scripts": {
    "boot": "KUMIKO_DRY_RUN_ENV=boot bun bin/main.ts",
    "build": "kumiko-build",
    "boot:bundled": "KUMIKO_DRY_RUN_ENV=boot bun dist-server/server.js",
    "dev": "PORT=4186 bun --env-file=../../../.env run src/app/server.ts",
    "screenshots": "bun x playwright test e2e/screenshots.spec.ts --config=playwright.config.ts",
    "gen:manifest": "bun run scripts/gen-feature-manifest.ts",
    "gen:sample-index": "bun run scripts/gen-sample-index.ts"
  },
  "dependencies": {
    "@cosmicdrift/kumiko-bundled-features": "workspace:*",
    "@cosmicdrift/kumiko-dev-server": "workspace:*",
    "@cosmicdrift/kumiko-dispatcher-live": "workspace:*",
    "@cosmicdrift/kumiko-framework": "workspace:*",
    "@cosmicdrift/kumiko-headless": "workspace:*",
    "@cosmicdrift/kumiko-renderer-web": "workspace:*",
    "@cosmicdrift/kumiko-server-runtime": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  }
}
