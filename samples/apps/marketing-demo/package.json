    "screenshots": "bun x playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@kumiko/bundled-features": "workspace:*",
    "@kumiko/dev-server": "workspace:*",
    "@kumiko/dispatcher-live": "workspace:*",
    "@kumiko/framework": "workspace:*",
    "@kumiko/headless": "workspace:*",
    "@kumiko/renderer-web": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
