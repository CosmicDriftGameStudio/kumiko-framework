    "screenshots": "bun x playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@cosmicdrift/kumiko-bundled-features": "workspace:*",
    "@cosmicdrift/kumiko-dev-server": "workspace:*",
    "@cosmicdrift/kumiko-dispatcher-live": "workspace:*",
    "@cosmicdrift/kumiko-framework": "workspace:*",
    "@cosmicdrift/kumiko-headless": "workspace:*",
    "@cosmicdrift/kumiko-renderer-web": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
