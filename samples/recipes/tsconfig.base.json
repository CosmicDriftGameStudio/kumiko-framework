{
  "_comment": "Single source of truth \u2014 check-app-tsc reads this template and overlays the @app/define branch for codegen recipes. Paths are relative to samples/recipes/<name>/.",
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@cosmicdrift/kumiko-framework/*": [
        "../../../packages/framework/src/*/index.ts"
      ],
      "@cosmicdrift/kumiko-bundled-features/*": [
        "../../../packages/bundled-features/src/*/index.ts"
      ],
      "@cosmicdrift/kumiko-dev-server": [
        "../../../packages/dev-server/src/index.ts"
      ],
      "@cosmicdrift/kumiko-dev-server/*": ["../../../packages/dev-server/src/*"]
    },
    "noEmit": true,
    "rootDir": "../../..",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["bun-types"]
  },
  "include": ["./src"]
}
