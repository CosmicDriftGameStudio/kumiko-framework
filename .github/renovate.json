{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "rangeStrategy": "bump",
  "schedule": ["before 6am on monday"],
  "timezone": "Europe/Berlin",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major"]
    },
    {
      "groupName": "type definitions",
      "automerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    },
    {
      "groupName": "drizzle",
      "matchPackageNames": [
        "/^drizzle/"
      ]
    },
    {
      "groupName": "biome",
      "matchPackageNames": [
        "/^@biomejs//"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "/^vitest$/",
        "/^@vitest//"
      ]
    },
    {
      "groupName": "testing-library",
      "matchPackageNames": [
        "/^@testing-library//"
      ]
    },
    {
      "groupName": "react",
      "matchPackageNames": [
        "/^react/",
        "/^@types/react/"
      ]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "automerge": true,
      "minimumReleaseAge": "0 days",
      "schedule": ["at any time"],
      "matchPackageNames": [
        "/^@cosmicdrift//",
        "/^@cosmicdriftgamestudio//"
      ]
    }
  ],
  "ignoreDeps": ["@cosmicdriftgamestudio/kumiko-guards"],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "schedule": ["at any time"]
  }
}
