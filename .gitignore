node_modules/
dist/
dist-server/
.expo/
.turbo/

# /platform ist Symlink zu ~/code/kumiko-platform (eigenes Repo).
# Im Hauptrepo nur for-eyes sichtbar, nicht versioned. Slash-Prefix
# anchored auf repo-root — sonst matcht es auch samples/apps/platform.
/platform
*.tsbuildinfo
.env
.env.*
!.env.example
.DS_Store
coverage/
test-results/
playwright-report/
.e2e-data.json
.kumiko-check.lock/
.kumiko-check.log
.kumiko-check.result

# Codegen-Output (pro app generiert via `yarn kumiko codegen`).
# Wrapper + Type-Map-Augmentation, aus den r.defineEvent-Aufrufen
# der App synthetisiert.
.kumiko/

# Migration-Runtime-State (sample-spezifisch, pro Run regeneriert)
.beammycar-checkpoint.json
.beammycar-checkpoint.json.tmp

# Codegen-test fixtures (created+removed per test run)
.tmp-fixtures/

# Yarn 4 (berry) — commit only the bundled yarn binary + plugins, ignore
# install-state and the cache. Zero-installs (committing .yarn/cache)
# deferred per docs/plans/yarn4-migration.md.
.yarn/*
!.yarn/releases
!.yarn/plugins
.pnp.*
