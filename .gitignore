.turbo/

# Claude Code session state (pro Run regeneriert + lokales worktree-staging).
.claude/scheduled_tasks.lock
.claude/worktrees/

# /platform ist Symlink zu ~/code/kumiko-platform (eigenes Repo).
# Im Hauptrepo nur for-eyes sichtbar, nicht versioned. Anchor zu root,
# damit `samples/apps/platform/` (echter In-Repo-Code) NICHT matched.
/platform
*.tsbuildinfo
.env
.env.*
!.env.example

# Lokale Compose-Overrides (dev-spezifisch: offline-Modell-Bind-Mount, alt. Ports).
docker-compose.override.yml
docker-compose.override.yaml
.DS_Store
coverage/
test-results/
playwright-report/
.e2e-data.json
.kumiko-check.lock/
.kumiko-check.log
.kumiko-check.result

# Codegen-Output (pro app generiert via `bun kumiko codegen`).
# Wrapper + Type-Map-Augmentation, aus den r.defineEvent-Aufrufen
# der App synthetisiert.
.kumiko/
# SQL-inventory baseline for guard-raw-sql / CI drift check (Phase 5).
!.kumiko/sql-inventory-baseline.json
# Aber: samples/recipes/*/.kumiko/ MUSS commited sein. Die 3 recipes
# (cross-feature-events, event-sourcing, state-machine) deklarieren
# "@app/define": "file:./.kumiko" als dep. CI's `bun install` braucht
# die Files VOR dem postinstall-codegen — sonst ENOENT. Lokal-Dev
# regeneriert via codegen-samples-postinstall on commit-time-Diff.
!samples/recipes/*/.kumiko/
!samples/recipes/*/.kumiko/**

# Migration-Runtime-State (sample-spezifisch, pro Run regeneriert)
.beammycar-checkpoint.json
.beammycar-checkpoint.json.tmp

# Codegen-test fixtures (created+removed per test run)
.tmp-fixtures/

# Bun install cache
~/.bun/install/cache
.aider*

# check-app-tsc scratch (written into recipe dirs during the check)
.check-tsconfig.json
